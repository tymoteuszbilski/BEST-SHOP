{
  "compilerOptions": {
    "target": "ES6",
    "module": "ESNext",
    "outDir": "./dist/js", // Compiled JS files go here
    "rootDir": "./src/ts", // TS source files
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowJs": false
  },
  "include": ["src/ts/**/*"],
  "exclude": ["node_modules", "dist"]
}
